      "parameters": {
        "functionCode": "const price = $json.property_price;\nconst rent = $json.rental_income;\nconst expenses = $json.expenses;\nconst appreciation = $json.appreciation_rate;\n\nconst annualRent = rent * 12;\nconst annualExpenses = expenses * 12;\n\nconst netIncome = annualRent - annualExpenses;\nconst roi = (netIncome / price) * 100;\nconst appreciationValue = (price * appreciation) / 100;\n\nreturn [{\n  json: {\n    price,\n    annualRent,\n    netIncome,\n    roi: roi.toFixed(2),\n    appreciationValue\n  }\n}];"
      },
      "id": "8b4ddf97-a681-4c79-90bd-c3f9642433a0",
