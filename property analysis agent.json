        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a professional real estate investment analyst.\\n\\nProperty Details:\\n- Property Price: {{$json.price}}\\n- Annual Rent: {{$json.annualRent}}\\n- Net Income: {{$json.netIncome}}\\n- ROI: {{$json.roi}}%\\n\\nReturn ONLY a valid JSON object in this format:\\n\\n{\\n  \\\"summary\\\": \\\"...\\\",\\n  \\\"key_metrics\\\": {\\n    \\\"property_price\\\": \\\"...\\\",\\n    \\\"annual_rent\\\": \\\"...\\\",\\n    \\\"net_income\\\": \\\"...\\\",\\n    \\\"roi\\\": \\\"...\\\"\\n  },\\n  \\\"strengths\\\": [\\\"...\\\", \\\"...\\\", \\\"...\\\"],\\n  \\\"risks\\\": [\\\"...\\\", \\\"...\\\", \\\"...\\\"],\\n  \\\"recommendation\\\": \\\"...\\\"\\n}\\n\\nIMPORTANT:\\n- Return ONLY JSON\\n- No extra text\\n- No markdown\\n- No explanation outside JSON\"\n        }\n      ]\n    }\n  ]\n}",
